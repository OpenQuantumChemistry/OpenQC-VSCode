#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# Run linter
echo "📋 Running ESLint..."
npm run lint || {
    echo "❌ ESLint failed. Please fix linting errors before committing."
    exit 1
}

# Run type checking
echo "🔎 Running TypeScript type check..."
npx tsc --noEmit || {
    echo "❌ TypeScript type check failed. Please fix type errors before committing."
    exit 1
}

# Run tests with coverage requirement
echo "🧪 Running tests with coverage requirement..."
npm run test:unit || {
    echo "❌ Tests failed. Please fix tests before committing."
    exit 1
}

# Run format check
echo "📝 Running format check..."
npm run format:check || {
    echo "❌ Format check failed. Run 'npm run format:write' to fix formatting."
    exit 1
}

echo "✅ All pre-commit checks passed!"
