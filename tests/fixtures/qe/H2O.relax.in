&CONTROL
  calculation = 'relax'
  restart_mode = 'from_scratch'
  prefix = 'water'
  outdir = './tmp/'
  pseudo_dir = './pseudo/'
  tprnfor = .true.
  tstress = .true.
/

&SYSTEM
  ibrav = 1
  celldm(1) = 15.0
  nat = 3
  ntyp = 2
  ecutwfc = 30.0
  ecutrho = 240.0
  input_dft = 'PBE'
/

&ELECTRONS
  conv_thr = 1.0d-6
  mixing_beta = 0.7
/

&IONS
  ion_dynamics = 'bfgs'
/

ATOMIC_SPECIES
  H   1.008   H.pbe-rrkjus_psl.1.0.0.UPF
  O  15.999  O.pbe-n-rrkjus_psl.1.0.0.UPF

ATOMIC_POSITIONS (angstrom)
  O   0.000000   0.000000   0.000000
  H   0.000000   0.757215   0.586535
  H   0.000000  -0.757215   0.586535

K_POINTS (gamma)
