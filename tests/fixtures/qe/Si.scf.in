&CONTROL
  calculation = 'scf'
  restart_mode = 'from_scratch'
  prefix = 'silicon'
  outdir = './tmp/'
  pseudo_dir = './pseudo/'
  verbosity = 'high'
/

&SYSTEM
  ibrav = 2
  celldm(1) = 10.26
  nat = 2
  ntyp = 1
  ecutwfc = 40.0
  ecutrho = 320.0
  occupations = 'smearing'
  smearing = 'gaussian'
  degauss = 0.02
/

&ELECTRONS
  conv_thr = 1.0d-8
  mixing_mode = 'plain'
  mixing_beta = 0.7
  diagonalization = 'david'
/

ATOMIC_SPECIES
  Si  28.086  Si.pz-vbc.UPF

ATOMIC_POSITIONS (alat)
  Si  0.000000   0.000000   0.000000
  Si  0.250000   0.250000   0.250000

K_POINTS (automatic)
  6 6 6 0 0 0
